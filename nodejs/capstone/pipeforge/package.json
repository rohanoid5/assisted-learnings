{
  "name": "pipeforge",
  "version": "0.1.0",
  "description": "Data pipeline & job processing system — Node.js learning capstone",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "node --watch --loader ts-node/esm src/api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "cli": "node --loader ts-node/esm src/cli/index.ts",
    "test": "node --experimental-test-runner --loader ts-node/esm --test 'tests/**/*.test.ts'",
    "test:unit": "node --experimental-test-runner --loader ts-node/esm --test 'tests/unit/**/*.test.ts'",
    "test:integration": "node --experimental-test-runner --loader ts-node/esm --test 'tests/integration/**/*.test.ts'",
    "test:e2e": "node --experimental-test-runner --loader ts-node/esm --test 'tests/e2e/**/*.test.ts'",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node --loader ts-node/esm src/db/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "ora": "^8.0.1",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.39",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
