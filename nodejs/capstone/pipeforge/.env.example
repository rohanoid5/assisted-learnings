# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/pipeforge_dev"

# Authentication
JWT_SECRET=your-super-secret-jwt-key-at-least-256-bits-long-change-in-production
JWT_EXPIRES_IN=86400  # seconds = 24 hours

# Worker Threads
WORKER_POOL_SIZE=4    # defaults to os.cpus().length / 2

# Optional: Redis (for job queue — added in Module 10)
# REDIS_URL=redis://localhost:6379
