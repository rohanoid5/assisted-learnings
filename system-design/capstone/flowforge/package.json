{
  "name": "flowforge",
  "version": "0.1.0",
  "description": "Distributed notification & event processing system — System Design capstone",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:event-service": "node --watch --loader ts-node/esm src/event-service/server.ts",
    "dev:delivery-worker": "node --watch --loader ts-node/esm src/delivery-worker/worker.ts",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-test-runner --loader ts-node/esm --test 'tests/**/*.test.ts'",
    "db:generate": "prisma generate --schema src/shared/db/schema.prisma",
    "db:migrate": "prisma migrate dev --schema src/shared/db/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.13.0",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.2",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
