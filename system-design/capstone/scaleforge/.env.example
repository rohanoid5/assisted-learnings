# Application
NODE_ENV=development
PORT=3002
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://scaleforge:secret@localhost:5432/scaleforge_dev

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# Rate Limiting (requests per minute per user tier)
RATE_LIMIT_FREE=60
RATE_LIMIT_PRO=600

# URL Config
BASE_URL=http://localhost:3001
CODE_LENGTH=6
DEFAULT_TTL_DAYS=90
