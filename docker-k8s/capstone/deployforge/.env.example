# DeployForge — Environment Variables
# Copy to .env and adjust as needed:  cp .env.example .env

# ── API Gateway ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ── PostgreSQL ──────────────────────────────────────────────────
DATABASE_URL=postgresql://deployforge:password@localhost:5432/deployforge_dev
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── Worker ──────────────────────────────────────────────────────
WORKER_CONCURRENCY=5

# ── Docker Compose port overrides ───────────────────────────────
API_PORT=3000
NGINX_PORT=8080

# ── Module 07: External Secrets ─────────────────────────────────
# SECRETS_PROVIDER=env
# AWS_REGION=us-east-1
# VAULT_ADDR=http://127.0.0.1:8200

# ── Module 08: OpenTelemetry ────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=deployforge-api
